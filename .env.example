# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ragdb?sslmode=disable

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# NATS
NATS_URL=nats://localhost:4222

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin123
MINIO_SECRET_KEY=password123
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# OpenAI / LLM
# For Ollama users:
#   OPENAI_BASE_URL=http://localhost:11434/v1
#   OPENAI_API_KEY=ollama
#   EMBEDDING_MODEL=qwen3-embedding  (dimension: 4096)
#   LLM_MODEL=qwen3:8b
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
EMBEDDING_MODEL=quentinz/bge-small-zh-v1.5:f32
LLM_MODEL=openbmb/minicpm-v4.5:8b

# Server
SERVER_PORT=8080
SERVER_ENV=development

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=24h

# BGE Rerank (Self-hosted Cross-Encoder reranking)
# See services/bge-rerank/ for Docker deployment
BGE_RERANK_ENABLED=false
BGE_RERANK_BASE_URL=http://localhost:8800
BGE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
BGE_RERANK_TOP_K=10
BGE_RERANK_CANDIDATES=50
